# NEVER commit credentials!
.env
.dvc/config.local  # Contains DVC credentials

# Data tracked by DVC, not Git

!store/data/raw/*.dvc
!store/data/processed/*.dvc
!store/models/*.dvc
!store/data/raw/.gitkeep
!store/data/processed/.gitkeep
!store/models/.gitkeep


# Environment variables - NEVER commit these!
.env
.env.local
.env.*.local

# DVC
/.dvc/config.local
/.dvc/tmp
/.dvc/cache

# Python
.venv
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
dist/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
# DVC and credentials (auto-added by setup script)
/.env


# DVC, credentials, and Python env (auto-added by setup script)
/.venv

vscode_cli.tar.gz