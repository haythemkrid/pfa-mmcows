# NEVER commit credentials!
.env
.dvc/config.local  # Contains DVC credentials

# Data tracked by DVC, not Git
store/data/raw/
store/data/processed/
store/models/
!store/data/raw/*.dvc
!store/data/processed/*.dvc
!store/models/*.dvc

# Environment variables - NEVER commit these!
.env
.env.local
.env.*.local

# DVC
/.dvc/config.local
/.dvc/tmp
/.dvc/cache

