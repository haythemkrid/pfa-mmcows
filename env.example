# DVC Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to git!

# DVC Remote Configuration
DVC_REMOTE_NAME=origin
DVC_S3_BUCKET=s3://dvc
DVC_ENDPOINT_URL=https://dagshub.com/haythemkrid/pfa-mmcows.s3

# DagHub Credentials
# Get these from: https://dagshub.com/user/settings/tokens
DVC_ACCESS_KEY_ID=your_access_key_here
DVC_SECRET_ACCESS_KEY=your_secret_key_here